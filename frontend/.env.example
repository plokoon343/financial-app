# Copy to .env.local for local dev, or set in Vercel → Settings → Environment Variables.
# Create React App inlines REACT_APP_* at BUILD time — changing it needs a redeploy.

# Backend API base URL (no trailing slash).
# Production (once api.automonie.com is live and serving HTTPS):
#   REACT_APP_API_URL=https://api.automonie.com
# Current default if unset:
#   https://financial-app-w2ai.onrender.com
REACT_APP_API_URL=https://financial-app-w2ai.onrender.com
